# PilotSwarm worker runtime environment
# Copy to: /etc/pilotswarm/worker.env

# Shared PostgreSQL used by both the worker and remote TUI/client.
DATABASE_URL=postgresql://user:password@db-host:5432/pilotswarm

# At least one model provider credential is required.
# Simplest path: GitHub Copilot token.
GITHUB_TOKEN=ghu_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# S3-backed session dehydration and artifacts.
AWS_S3_BUCKET_NAME=pilot-swarm
AWS_S3_REGION=us-east-1

# Optional for standard AWS S3. Leave unset unless you need a custom endpoint.
# AWS_S3_ENDPOINT=https://s3.us-east-1.amazonaws.com

# Only needed if you are not using an EC2 IAM role.
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# Optional worker settings.
LOG_LEVEL=info
# PLUGIN_DIRS=/app/plugin
# POD_NAME=ec2-worker-1

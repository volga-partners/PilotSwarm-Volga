{
  "mcpServers": {
    "pilotswarm": {
      "type": "http",
      "url": "http://127.0.0.1:3100/mcp",
      "description": "PilotSwarm MCP server — sessions, agents, facts, models",
      "headers": {
        "Authorization": "Bearer pilotswarm-local-dev-key"
      },
      "tools": [
        "create_session",
        "list_sessions",
        "get_session_detail",
        "send_message",
        "send_and_wait",
        "send_answer",
        "abort_session",
        "rename_session",
        "delete_session",
        "spawn_agent",
        "list_agents",
        "message_agent",
        "cancel_agent",
        "store_fact",
        "read_facts",
        "delete_fact",
        "switch_model",
        "send_command"
      ],
      "resources": [
        "pilotswarm://sessions",
        "pilotswarm://sessions/{id}",
        "pilotswarm://sessions/{id}/messages",
        "pilotswarm://facts",
        "pilotswarm://models"
      ]
    },
    "pilotswarm-stdio": {
      "type": "stdio",
      "command": "node",
      "args": [
        "packages/mcp-server/dist/bin/pilotswarm-mcp.js",
        "--store", "postgresql://postgres:postgres@localhost:5432/durable_copilot",
        "--model-providers", ".model_providers.json"
      ],
      "env": {
        "DATABASE_URL": "postgresql://postgres:postgres@localhost:5432/durable_copilot",
        "NODE_OPTIONS": "--env-file=.env"
      },
      "description": "PilotSwarm MCP server (stdio transport) — for local IDE integration"
    }
  }
}

{
  "name": "pilotswarm-cli",
  "version": "0.1.14",
  "description": "Terminal UI for PilotSwarm.",
  "type": "module",
  "bin": {
    "pilotswarm": "./bin/tui.js",
    "pilotswarm-cli": "./bin/tui.js"
  },
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "scripts": {
    "build": "echo 'pilotswarm-cli: no build step (plain JS)'",
    "start": "node ./bin/tui.js local --env ../../.env.remote",
    "start:remote": "node ./bin/tui.js remote --env ../../.env.remote",
    "clean": "true"
  },
  "keywords": [
    "copilot",
    "pilotswarm",
    "tui",
    "agent",
    "cli"
  ],
  "author": "Affan Dar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/affandar/PilotSwarm"
  },
  "homepage": "https://github.com/affandar/PilotSwarm",
  "bugs": {
    "url": "https://github.com/affandar/PilotSwarm/issues"
  },
  "dependencies": {
    "ink": "^6.8.0",
    "pilotswarm-sdk": "^0.1.12",
    "pilotswarm-ui-core": "0.1.0",
    "pilotswarm-ui-react": "0.1.0",
    "react": "^19.2.4"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "files": [
    "bin/**/*",
    "src/**/*",
    "tui-splash.txt",
    "plugins/**/*",
    "README.md"
  ]
}

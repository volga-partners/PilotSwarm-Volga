# GitHub token for Copilot API access (fallback, not needed with custom LLM)
# Use: gh auth token
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Microsoft AI Foundry Model deployment keys
AZURE_MODEL_ROUTER_KEY=your-azure-model-router-key
AZURE_FW_GLM5_KEY=your-azure-fw-glm5-key
AZURE_KIMI_K25_KEY=your-azure-kimi-k25-key
AZURE_OAI_KEY=your-azure-openai-key

# Anthropic API key (direct API access for Claude models)
# ANTHROPIC_API_KEY=your-anthropic-api-key

# Model selection is managed by model_providers.json
# Override with COPILOT_MODEL env var only if needed.

# Duroxide PostgreSQL store (local Docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/durable_copilot

# Azure Blob Storage for session dehydration/hydration
# Disabled for local runs so PilotSwarm uses filesystem session/artifact stores.
# Re-enable or use .env.remote for blob-backed remote runs.
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_CONTAINER=copilot-sessions

# Entra ID auth for the web portal (optional — omit to disable auth)
# Register an app in Azure AD → copy client ID and tenant ID.
# ENTRA_TENANT_ID=<your-entra-tenant-id>
# ENTRA_CLIENT_ID=<your-entra-client-id>

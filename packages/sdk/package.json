{
  "name": "pilotswarm",
  "version": "0.1.0",
  "description": "A durable execution runtime for GitHub Copilot SDK agents. Crash recovery, durable timers, session dehydration, and multi-node scaling — powered by duroxide.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --env-file=../../.env test/sdk.test.js",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "copilot",
    "durable",
    "duroxide",
    "agent",
    "orchestration",
    "async"
  ],
  "author": "Affan Dar",
  "license": "MIT",
  "dependencies": {
    "@azure/storage-blob": "^12.31.0",
    "@github/copilot": "^1.0.2",
    "@github/copilot-sdk": "^0.1.32",
    "duroxide": "^0.1.14",
    "duroxide-darwin-arm64": "^0.1.14",
    "pg": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.16.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "files": [
    "dist/**/*",
    "plugins/**/*",
    "README.md"
  ]
}

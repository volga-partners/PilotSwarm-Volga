# PilotSwarm Portal Frontend Configuration

# Backend API Base URL
# Set this to point to your PilotSwarm Portal Backend
# Development: http://localhost:3001
# Production: https://your-backend-domain.com
VITE_PORTAL_API_BASE_URL=http://localhost:3001

# GitHub Token (optional, for Copilot API access)
# GITHUB_TOKEN=your-github-token

# Azure Keys (optional, for Azure deployments)
# AZURE_MODEL_ROUTER_KEY=your-key
# AZURE_FW_GLM5_KEY=your-key
# AZURE_KIMI_K25_KEY=your-key
# AZURE_GPT51_KEY=your-key

# Anthropic API Key (optional)
# ANTHROPIC_API_KEY=your-api-key

# ─── GitHub Copilot API ────────────────────────────────────────────
# Required. Your GitHub token with Copilot access.
# Get it by running: gh auth token
# Or create a PAT at https://github.com/settings/tokens with copilot scope.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Duroxide Store (database) ────────────────────────────────────
# Required. PostgreSQL connection string for duroxide orchestration + CMS.
# For local development, run Postgres in Docker:
#   docker run -d --name durable-pg -p 5432:5432 \
#     -e POSTGRES_PASSWORD=postgres \
#     -e POSTGRES_DB=durable_copilot \
#     postgres:16
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/durable_copilot

# For quick testing without Postgres, use SQLite (in-memory):
# DATABASE_URL=sqlite::memory:

# ─── Azure Blob Storage (optional) ───────────────────────────────
# Optional. Used for session dehydration/hydration (long waits, pod relocation).
# Not needed for local dev or single-process mode.
# Create a storage account + container in Azure, then paste the connection string.
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
# AZURE_STORAGE_CONTAINER=copilot-sessions

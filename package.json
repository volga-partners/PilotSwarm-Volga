{
  "name": "durable-copilot-runtime",
  "version": "0.1.0",
  "description": "A durable execution runtime for GitHub Copilot SDK agents. Crash recovery, durable timers, session dehydration, and multi-node scaling — powered by duroxide.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "durable-copilot-runtime-tui": "./bin/tui.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --env-file=.env test/sdk.test.js",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "chat": "node --env-file=.env examples/chat.js",
    "tui": "node bin/tui.js local --env .env.remote",
    "tui:remote": "node bin/tui.js remote --env .env.remote",
    "worker": "node --env-file=.env.remote examples/worker.js",
    "db:reset": "node --env-file=.env scripts/db-reset.js"
  },
  "keywords": [
    "copilot",
    "durable",
    "duroxide",
    "agent",
    "orchestration",
    "async"
  ],
  "author": "Affan Dar",
  "license": "MIT",
  "dependencies": {
    "@azure/storage-blob": "^12.31.0",
    "@github/copilot": "^0.0.420",
    "@github/copilot-sdk": "^0.1.29",
    "chalk": "^5.6.2",
    "duroxide": "^0.1.7",
    "duroxide-darwin-arm64": "^0.1.5",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "neo-blessed": "^0.1.81",
    "pg": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.16.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "files": [
    "dist/**/*",
    "bin/**/*",
    "cli/tui.js",
    "plugin/**/*",
    "README.md"
  ]
}

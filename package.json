{
  "name": "pilotswarm-monorepo",
  "private": true,
  "type": "module",
  "description": "Monorepo for pilotswarm SDK and CLI.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspace=packages/sdk",
    "test": "npm test --workspace=packages/sdk",
    "test:local": "npm run test:local --workspace=packages/sdk",
    "test:local:smoke": "npm run test:local:smoke --workspace=packages/sdk",
    "test:local:durability": "npm run test:local:durability --workspace=packages/sdk",
    "test:local:multi-worker": "npm run test:local:multi-worker --workspace=packages/sdk",
    "test:local:commands": "npm run test:local:commands --workspace=packages/sdk",
    "test:local:sub-agents": "npm run test:local:sub-agents --workspace=packages/sdk",
    "test:local:kv-transport": "npm run test:local:kv-transport --workspace=packages/sdk",
    "test:local:cms": "npm run test:local:cms --workspace=packages/sdk",
    "test:local:contracts": "npm run test:local:contracts --workspace=packages/sdk",
    "test:local:chaos": "npm run test:local:chaos --workspace=packages/sdk",
    "lint": "npm run lint --workspace=packages/sdk",
    "clean": "npm run clean --workspaces",
    "perf:spawn": "node --env-file=.env scripts/perf/run-sdk-spawn-perf.mjs",
    "perf:spawn:raw": "npm run test:perf:spawn --workspace=packages/sdk",
    "chat": "node --env-file=.env packages/sdk/examples/chat.js",
    "tui": "npm run tui --workspace=packages/cli",
    "tui:remote": "npm run tui:remote --workspace=packages/cli",
    "worker": "node --env-file=.env.remote packages/sdk/examples/worker.js",
    "db:reset": "node --env-file=.env scripts/db-reset.js",
    "postinstall": "node scripts/postinstall.js"
  },
  "author": "Affan Dar",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  }
}
